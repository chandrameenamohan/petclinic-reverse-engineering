# =============================================================================
# Petclinic Python — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# --- Service URLs (for local development) ---
CONFIG_SERVER_URL=http://localhost:8888
DISCOVERY_SERVER_URL=http://localhost:8761
CUSTOMERS_SERVICE_URL=http://localhost:8081
VISITS_SERVICE_URL=http://localhost:8082
VETS_SERVICE_URL=http://localhost:8083
GENAI_SERVICE_URL=http://localhost:8084

# --- Database (dev: sqlite, prod: postgresql) ---
DATABASE_URL=sqlite+aiosqlite:///./petclinic.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/petclinic

# --- OpenAI (GenAI service) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# --- Observability ---
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
PROMETHEUS_PORT=9091

# --- Logging ---
LOG_LEVEL=INFO
